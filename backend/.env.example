PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb://127.0.0.1:27017/meet-app
JWT_SECRET=replace-with-long-random-secret
JWT_EXPIRES_IN=7d
# Comma-separated list of allowed origins for CORS + Socket.IO
# e.g. "https://app.netlify.app,https://preview.netlify.app"
CLIENT_ORIGIN=http://localhost:5173

# Canonical URL used when building email links (password reset, etc.).
# Defaults to the first CLIENT_ORIGIN when unset.
APP_URL=

MAX_PARTICIPANTS_PER_ROOM=50

# Password reset
PASSWORD_RESET_TTL_MINUTES=30

# SMTP (optional — if unset, reset links are printed to the server console in dev)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=ClassMeet <no-reply@classmeet.local>
